// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model HealthCheck {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

model User {
  id                String           @id @default(cuid())
  name              String
  email             String?          @unique
  passwordHash      String?
  role              Role
  bio               String?
  photoUrl          String?
  coverUrl          String?
  coverOffsetY      Float            @default(50)
  accentColor       String?
  paymentDetails    String?
  locale            String           @default("en")
  phone             String?
  idNumber          Int?             @unique
  levelId           String?
  level             Level?           @relation("StudentLevel", fields: [levelId], references: [id], onDelete: SetNull)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  coursesTaught     Course[]
  enrollments       Enrollment[]
  approvedPayments  Payment[]
  attendances       Attendance[]
  childLinks        ParentStudent[]  @relation("ParentOf")
  parentLinks       ParentStudent[]  @relation("ChildOf")
  teacherLinks      TeacherStudent[] @relation("TeacherOf")
  studentLinks      TeacherStudent[] @relation("StudentOf")
  pushSubscriptions PushSubscription[]
  levels            Level[]            @relation("TeacherLevels")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model TeacherStudent {
  teacherId String
  studentId String
  teacher   User     @relation("TeacherOf", fields: [teacherId], references: [id], onDelete: Cascade)
  student   User     @relation("StudentOf", fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([teacherId, studentId])
  @@index([studentId])
}

model ParentStudent {
  id        String   @id @default(cuid())
  parentId  String
  parent    User     @relation("ParentOf", fields: [parentId], references: [id])
  studentId String
  student   User     @relation("ChildOf", fields: [studentId], references: [id])
  createdAt DateTime @default(now())

  @@unique([parentId, studentId])
  @@index([studentId])
}

model Level {
  id            String   @id @default(cuid())
  name          String
  order         Int
  description   String?
  parentLevelId String?
  teacherId     String?
  parent        Level?   @relation("LevelChildren", fields: [parentLevelId], references: [id], onDelete: Cascade)
  children      Level[]  @relation("LevelChildren")
  teacher       User?    @relation("TeacherLevels", fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  courses       Course[]
  students      User[]   @relation("StudentLevel")

  @@index([order])
  @@index([parentLevelId])
  @@index([teacherId])
}

enum SessionType {
  ONLINE
  OFFLINE
}

enum PaymentFrequency {
  ONE_TIME
  MONTHLY
  PER_SEMESTER
}

model Course {
  id          String         @id @default(cuid())
  title       String
  description String?
  price            Int?
  sessionType      SessionType
  paymentFrequency PaymentFrequency @default(MONTHLY)
  isActive         Boolean          @default(true)
  levelId          String
  level       Level          @relation(fields: [levelId], references: [id])
  teacherId   String
  teacher     User           @relation(fields: [teacherId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sessions    ClassSession[]
  semesters   Semester[]

  @@index([teacherId])
  @@index([levelId])
}

model ClassSession {
  id          String       @id @default(cuid())
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  semesterId  String
  semester    Semester     @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  attendances Attendance[]

  @@unique([courseId, startTime])
  @@index([courseId])
  @@index([semesterId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

model Attendance {
  id           String           @id @default(cuid())
  studentId    String
  student      User             @relation(fields: [studentId], references: [id])
  sessionId    String
  session      ClassSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  status       AttendanceStatus
  checkInTime  DateTime?
  checkOutTime DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([studentId, sessionId])
  @@index([sessionId])
}

model Semester {
  id          String       @id @default(cuid())
  courseId    String
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  enrollments Enrollment[]
  sessions    ClassSession[]

  @@index([courseId])
}

model Enrollment {
  id         String    @id @default(cuid())
  studentId  String
  student    User      @relation(fields: [studentId], references: [id])
  semesterId String
  semester   Semester  @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  payments   Payment[]

  @@unique([studentId, semesterId])
  @@index([semesterId])
}

enum PaymentMethod {
  ONLINE
  CASH
}

enum PaymentStatus {
  PENDING
  APPROVED
}

model Payment {
  id           String        @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  month        DateTime
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  proofUrl     String?
  approvedById String?
  approvedBy   User?         @relation(fields: [approvedById], references: [id])
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([enrollmentId, month])
  @@index([enrollmentId])
}
